{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@cmd/*": ["src/cmd/*"],
      "@lib/*": ["src/lib/*"]
    },
    "types": ["@types/bun"],
    "verbatimModuleSyntax": true,
    "noEmit": true
  },
  "include": ["src", "tools"],
  "exclude": ["dist", "node_modules"]
}
